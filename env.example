# Environment Configuration

# Environment
ENVIRONMENT=development
DEBUG=true

# Database
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=fraud_detection
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TRANSACTIONS=transactions
KAFKA_TOPIC_ALERTS=alerts
KAFKA_CONSUMER_GROUP=fraud-detection-group

# API
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# Models
FRAUD_THRESHOLD=0.6
ANOMALY_THRESHOLD=0.7
GRAPH_RISK_THRESHOLD=0.65

# Alerts
ALERTS_ENABLED=true
EMAIL_RECIPIENTS=alerts@company.com
SLACK_WEBHOOK_URL=

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=8001
LOG_LEVEL=INFO